{
  "name": "tmp-scaffold",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest --run",
    "test:render": "vitest --run --passWithNoTests \"src/**/*.render.test.ts\" \"src/**/*.render.test.tsx\"",
    "test.e2e": "playwright test",
    "test.e2e:install": "playwright install chromium",
    "test:perf": "playwright test e2e/performance/tabs-performance.spec.ts",
    "test.unit": "vitest",
    "test:all": "npm run test && npm run test:render && npm run test.e2e",
    "lint:eslint": "eslint .",
    "lint:structure": "node ./scripts/check-structure.mjs",
    "lint": "npm run lint:eslint && npm run lint:structure",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "lighthouse": "lhci autorun --config=.lighthouserc.json",
    "lighthouse:ci": "lhci autorun --config=.lighthouserc.ci.json",
    "prepare": "husky"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "src/**/*.tsx": [
      "eslint --fix",
      "prettier --write"
    ],
    "src/**/*.css": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@capacitor/app": "8.0.1",
    "@capacitor/core": "8.2.0",
    "@capacitor/haptics": "8.0.1",
    "@capacitor/keyboard": "8.0.1",
    "@capacitor/status-bar": "8.0.1",
    "@ionic/react": "^8.5.0",
    "@ionic/react-router": "^8.5.0",
    "@types/react-router": "^5.1.20",
    "@types/react-router-dom": "^5.3.3",
    "ionicons": "^7.4.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-router": "^5.3.4",
    "react-router-dom": "^5.3.4"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-angular": "^20.5.0",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.53.2",
    "@capacitor/cli": "8.2.0",
    "@testing-library/dom": ">=7.21.4",
    "@testing-library/jest-dom": "^5.16.5",
    "@testing-library/react": "^16.2.0",
    "@testing-library/user-event": "^14.4.3",
    "@types/react": "19.0.10",
    "@types/react-dom": "19.0.4",
    "@vitejs/plugin-legacy": "^5.0.0",
    "@vitejs/plugin-react": "^4.0.1",
    "eslint": "^9.20.1",
    "eslint-plugin-jsdoc": "^48.11.0",
    "eslint-plugin-react": "^7.32.2",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^15.15.0",
    "husky": "^9.1.7",
    "jsdom": "^22.1.0",
    "lint-staged": "^16.4.0",
    "msw": "^2.10.4",
    "prettier": "^3.6.2",
    "terser": "^5.4.0",
    "typescript": "~5.9.0",
    "typescript-eslint": "^8.24.0",
    "vite": "^5.0.0",
    "vitest": "^0.34.6",
    "web-vitals": "^5.1.0"
  },
  "description": "An Ionic React project",
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
